{
  "name": "@pawclaw/desktop",
  "version": "0.1.0",
  "private": true,
  "productName": "PawClaw",
  "description": "A local animated desktop companion and chat for OpenClaw.",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "vite build && tsc -p tsconfig.electron.json",
    "dev": "npm --prefix ../.. run build && set ELECTRON_RUN_AS_NODE=&& electron .",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "@pawclaw/openclaw-client": "0.1.0",
    "@pawclaw/persistence": "0.1.0",
    "@pawclaw/pet-engine": "0.1.0",
    "@pawclaw/pet-sdk": "0.1.0",
    "@pawclaw/shared": "0.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^36.2.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
